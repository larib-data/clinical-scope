                "range": [0, 30]
            },
            "EtCO2(mmHg)": {
                "label": "EtCO2",
                "unit": "mmHg",
                "range": [20, 60]
            }
        },
        "numerics": {
            "period_resampling": 0.2,
            "priority": 2
        },
        "grouped_fields": {
            "Pressures": ["PEEP(cmH2O)", "PIP(cmH2O)", "Pplat(cmH2O)", "DrivingPaw(cmH2O)"],
            "Compliance": ["Cdyn(ml/cmH2O)", "Cstat(ml/cmH2O)"]
