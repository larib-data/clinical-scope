{
    "global": {
        "grouped_fields": {
            "NI Pressure": ["PNId", "PNIm", "PNIs"],
            "Paw [cross-source qualified refs]": [
                "fluxmed_signals::Paw(cmH2O)",
                "mindray_scope::Paw",
                "mindray_respi_waves::MDC_PRESS_AWAY-MDC_DIM_CM_H2O"
            ]
        }
    },

    "philips_waves": {
        "field_display": ["art", "pleth", "paw", "vol"],
        "signals": {
            "art": {
                "label": "Arterial Pressure",
                "unit": "mmHg",
                "color": "red",
                "range": [0, 200]
            },
            "pleth": {
                "label": "Plethysmography",
                "unit": "AU",
                "color": "purple"
            },
            "paw": {
                "label": "Airway Pressure",
                "unit": "cmH2O",
                "range": [-5, 60],
                "color": "steelblue",
                "priority": 2
            },
            "vol": {
                "label": "Tidal Volume",
                "unit": "mL",
                "range": [-50, 600],
                "priority": 2,
                "line_dash": "dash"
            }
        },
        "numerics": {
            "period_resampling": 0.5,
            "priority": 1
        },
        "grouped_fields": {
            "Respiratory waves": ["paw", "vol"]
        },
        "loop": {
            "PV loop": ["paw", "vol"]
        }
    },

    "eit": {
        "field_display": [
            "Global",
            "Local 1*",
            "Local 2*",
            "Local 3*",
            "Local 4*",
            "%Local 1*",
            "%Local 2*",
            "%Local 3*",
            "%Local 4*"
        ],
        "signals": {
            "Global": {
                "unit": "Ohms",
                "color": "black"
            },
            "Local 1*": {
                "unit": "Ohms",
                "color": "red"
            },
            "Local 2*": {
                "unit": "Ohms",
                "color": "blue"
            },
            "Local 3*": {
                "unit": "Ohms",
                "color": "green"
            },
            "Local 4*": {
                "unit": "Ohms",
                "color": "purple"
            },
            "%Local 1*": {
                "unit": "Proportion",
                "color": "red",
                "range": [-0.05, 1.05],
                "hover_template": "fraction"
            },
            "%Local 2*": {
                "unit": "Proportion",
                "color": "blue",
                "hover_template": "percentage"
            },
            "%Local 3*": {
                "unit": "Proportion",
                "color": "green"
            },
            "%Local 4*": {
                "unit": "Proportion",
                "color": "purple"
            }
        },
        "numerics": {
            "period_resampling": 0.2,
            "priority": 2.5
        },
        "grouped_fields": {
            "Impedance value": [
                "Global",
                "Local 1*",
                "Local 2*",
                "Local 3*",
                "Local 4*"
            ],
            "Impedance proportion": [
                "Global",
                "%Local 1*",
                "%Local 2*",
                "%Local 3*",
                "%Local 4*"
            ]
        },
        "additional_informations": {
            "timezone": "Europe/Paris"
        }
    },

    "philips_numerics": {
        "field_display": [
            "FC",
            "SpO₂",
            "FiO₂",
            "ARTd",
            "ARTm",
            "ARTs",
            "PNId",
            "PNIm",
            "PNIs",
            "PEP",
            "Pplat.",
            "VMexp",
            "FR"
        ],
        "signals": {
            "FC": {
                "label": "Heart Rate",
                "unit": "bpm",
                "color": "#e31a1c",
                "range": [0, 200],
                "hover_template": "<b>HR:</b> %{y:.0f} bpm<extra></extra>"
            },
            "SpO₂": {
                "label": "SpO2",
                "unit": "%",
                "range": [80, 100]
            },
            "FiO₂": {
                "unit": "%"
            },
            "ARTd": {
                "label": "ART diastolic",
                "unit": "mmHg",
                "priority": 1.5
            },
            "ARTm": {
                "label": "ART mean",
                "unit": "mmHg",
                "priority": 1.5
            },
            "ARTs": {
                "label": "ART systolic",
                "unit": "mmHg",
                "priority": 1.5
            },
            "PNId": {
                "label": "NI Pressure diastolic",
                "unit": "mmHg"
            },
            "PNIm": {
                "label": "NI Pressure mean",
                "unit": "mmHg"
            },
            "PNIs": {
                "label": "NI Pressure systolic",
                "unit": "mmHg"
            },
            "PEP": {
                "label": "PEEP",
                "unit": "cmH2O",
                "range": [-2, 20]
            },
            "Pplat.": {
                "label": "Plateau Pressure",
                "unit": "cmH2O",
                "range": [0, 40]
            },
            "VMexp": {
                "label": "Minute Volume (exp)",
                "unit": "L/min"
            },
            "FR": {
                "label": "Respiratory Rate",
                "unit": "/min",
                "range": [0, 40]
            }
        },
        "grouped_fields": {
            "ART Pressure": ["ARTd", "ARTm", "ARTs"]
        }
    },

    "syringe": {
        "field_display": [
            "Vitesse Propofol",
            "Vitesse Remifentanil",
            "Vitesse Babynoradrenaline",
            "Effet Propofol",
            "Effet Remifentanil"
